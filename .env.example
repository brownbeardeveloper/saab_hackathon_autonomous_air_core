# Frontend server
PORT=3000
HOSTNAME=0.0.0.0

# Python bridge runtime
GAT_PYTHON_BIN=python3
GAT_PYTHON_ARGS=

# Fleet bridge defaults
FLEET_CONFIG_PATH=config.yml
FLEET_MISSIONS_FILE=generated_missions_100.json
FLEET_MODEL_PATH=models/best_model.zip
FLEET_SESSIONS_DIR=/app/.fleet_web_sessions

# Discord notifications
DISCORD_WEBHOOK_URL=

# Container timezone
TZ=Europe/Stockholm
